# Public values: set these in .env.local for local development and in Vercel for every deployment environment.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key

# Server-only value. Never prefix this with NEXT_PUBLIC_.
SUPABASE_SECRET_KEY=your-supabase-secret-key

# Canonical public origin. Used by Supabase email confirmations.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
