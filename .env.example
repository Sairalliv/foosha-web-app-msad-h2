# ── Future database & auth config ──────────────────────────────────
# Not used yet — the app currently runs entirely on a localStorage
# mock store (see src/data/localStore.ts) and a mock auth context
# (see src/context/AuthContext.tsx). Nothing needs to be filled in
# below for the app to run today.
#
# When you're ready to connect a real backend (Supabase, per the
# existing stack from Balance Hub), copy this file to `.env.local`
# and fill in real values. Vite only exposes variables prefixed with
# VITE_ to client code, so keep that prefix.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
